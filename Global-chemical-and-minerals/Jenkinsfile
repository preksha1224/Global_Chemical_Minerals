pipeline {
    agent any

    environment {
        AWS_REGION = 'us-west-1'
        ACCOUNT_ID = '973294445568'
        ECR_REPO = 'myappreact'

        IMAGE_TAG = "latest"
        ECR_URI = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}"

        ECS_CLUSTER = 'clustertask'
        ECS_SERVICE = 'connect1-service-af85vv5l'
    }

  stages {

    stage('Checkout') {
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: '*/main']],
          userRemoteConfigs: [[
            url: 'https://github.com/preksha1224/Global_Chemical_Minerals.git',
            credentialsId: ''
          ]]
        ])
      }
    }

    stage('Debug Files') {
      steps {
        sh 'pwd'
        sh 'ls -la'
      }
    }
    stages {

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t $ECR_REPO:$IMAGE_TAG .
                '''
            }
        }

    stage('Install Dependencies') {
      steps {
        sh 'npm install'
      }
    }

    stage('Lint / Test') {
      steps {
        sh 'npm test -- --watch=false --browsers=ChromeHeadless'
      }
    }

    stage('Build') {
      steps {
        sh 'npm run build -- --configuration production'
      }
    }
  }

  post {
    success {
      archiveArtifacts artifacts: 'dist/**', fingerprint: true
      junit allowEmptyResults: true, testResults: 'test-results/**/*.xml'
    }
    failure {
      echo 'Build failed. Please check console output for details.'
    }
  }
}
