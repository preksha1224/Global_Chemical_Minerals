pipeline {
  agent any

  environment {
    NODE_OPTIONS = '--max_old_space_size=4096'
  }

  stages {

    stage('Checkout') {
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: '*/main']],
          userRemoteConfigs: [[
            url: 'https://github.com/preksha1224/Global_Chemical_Minerals.git',
            credentialsId: ''
          ]]
        ])
      }
    }

    // 🔍 Debug stage (helps avoid path issues)
    stage('Debug Files') {
      steps {
        sh 'echo "Current Directory:"'
        sh 'pwd'
        sh 'echo "Listing files:"'
        sh 'ls -la'
      }
    }

    stage('Install Dependencies') {
      steps {
        dir('frontend') {   // ⚠️ change if your folder name is different
          sh 'npm install'
        }
      }
    }

    stage('Lint / Test') {
      steps {
        dir('frontend') {
          sh 'npm test -- --watch=false --browsers=ChromeHeadless || true'
        }
      }
    }

    stage('Build') {
      steps {
        dir('frontend') {
          sh 'npm run build -- --configuration production'
        }
      }
    }
  }

  post {
    success {
      archiveArtifacts artifacts: 'frontend/dist/**', fingerprint: true
      junit allowEmptyResults: true, testResults: 'frontend/test-results/**/*.xml'
    }
    failure {
      echo 'Build failed. Please check console output for details.'
    }
  }
}
