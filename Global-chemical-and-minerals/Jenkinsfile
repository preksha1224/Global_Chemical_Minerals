pipeline {
    agent any

    environment {
        NODE_OPTIONS = '--max_old_space_size=4096'
        // Apache server details - replace with your actual values
        APACHE_HOST = 'your-apache-server-ip-or-hostname'
        APACHE_USER = 'your-ssh-username'
        APACHE_PATH = '/var/www/html'  // Apache document root
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/preksha1224/Global_Chemical_Minerals.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Global-chemical-and-minerals') {
                    sh 'npm install'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('Global-chemical-and-minerals') {
                    sh 'npm run test -- --watch=false --browsers=ChromeHeadless'
                }
            }
        }

        stage('Build App') {
            steps {
                dir('Global-chemical-and-minerals') {
                    sh 'npm run build -- --configuration production'
                }
            }
        }

        stage('Deploy to Apache') {
            steps {
                dir('Global-chemical-and-minerals') {
                    // Install sshpass if needed, or use SSH key
                    sh '''
                    # Assuming SSH key is set up, or use sshpass
                    # Install rsync if not available
                    rsync -avz --delete dist/global-chemical-and-minerals/ ${APACHE_USER}@${APACHE_HOST}:${APACHE_PATH}/
                    '''
                }
            }
        }
    }

    post {
        success {
            echo '✅ Deployment to Apache Successful!'
            // Optional: Send notification
        }
        failure {
            echo '❌ Build or Deployment failed. Check logs.'
            // Optional: Send notification
        }
        always {
            // Clean up workspace
            cleanWs()
        }
    }
}