pipeline {
    agent any

    environment {
        APP_DIR = "Global-chemical-and-minerals"
        BUILD_DIR = "dist/global-chemical-and-minerals"
        DEPLOY_DIR = "/var/www/html"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/preksha1224/Global_Chemical_Minerals.git'
            }
        }

        stage('Verify Project Structure') {
            steps {
                sh 'ls -la'
                dir("${APP_DIR}") {
                    sh 'ls -la'
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${APP_DIR}") {
                    sh 'npm install'
                }
            }
        }

        stage('Build Angular App') {
            steps {
                dir("${APP_DIR}") {
                    sh 'npx ng build --configuration=production'
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                echo "Deploying application..."

                # Clean old files
                rm -rf ${DEPLOY_DIR}/*

                # Copy new build files
                cp -r ${APP_DIR}/${BUILD_DIR}/* ${DEPLOY_DIR}/

                echo "Deployment completed"
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Deployment Successful"
        }
        failure {
            echo "❌ Deployment Failed"
        }
    }
}